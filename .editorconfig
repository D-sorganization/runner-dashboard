# EditorConfig: https://editorconfig.org
# Top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py}]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,json}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{md,markdown}]
indent_size = 2
trim_trailing_whitespace = false

[*.sh]
indent_size = 2
end_of_line = lf

[Makefile]
indent_style = tab
