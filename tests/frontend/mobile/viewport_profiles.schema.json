{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runner dashboard mobile viewport profiles",
  "type": "object",
  "required": ["version", "playwright", "profiles", "smokePages", "visualRegression"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "playwright": {
      "type": "object",
      "required": ["browserName", "headless", "hasTouch", "isMobile"]
    },
    "profiles": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "viewport", "deviceScaleFactor"]
      }
    },
    "smokePages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "tabLabel", "requiredMarkers", "goldenInteraction"]
      }
    },
    "visualRegression": {
      "type": "object",
      "required": ["state", "enabledInCi", "baselineDir", "updateFlag", "failureArtifacts"]
    }
  }
}
