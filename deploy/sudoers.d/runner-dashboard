# /etc/sudoers.d/runner-dashboard
# Tightly-scoped passwordless-sudo for the runner-dashboard service account.
#
# This file must be installed with mode 0440:
#   sudo install -m 0440 deploy/sudoers.d/runner-dashboard /etc/sudoers.d/runner-dashboard
#
# Validate with: sudo visudo -c -f /etc/sudoers.d/runner-dashboard
#
# Only the exact systemctl verbs the dashboard's web API is permitted to call
# are listed here. Any other systemctl invocation will be rejected by sudo.
#
# Referenced code: backend/server.py _fleet_control_local(), run_runner_svc().
# See issue #391 AC-6.

# --- Command aliases (only these binaries and arguments are allowed) ----------

# systemctl verbs for the runner-dashboard service itself
Cmnd_Alias DASHBOARD_RESTART = /bin/systemctl --user restart runner-dashboard

# systemctl verbs for individual GitHub Actions runner services
# Pattern: actions.runner.<org>-<repo>.<num>.service
Cmnd_Alias RUNNER_SVC_START   = /bin/systemctl --user start   actions.runner.*.service
Cmnd_Alias RUNNER_SVC_STOP    = /bin/systemctl --user stop    actions.runner.*.service
Cmnd_Alias RUNNER_SVC_RESTART = /bin/systemctl --user restart actions.runner.*.service
Cmnd_Alias RUNNER_SVC_STATUS  = /bin/systemctl --user is-active actions.runner.*.service

# Maxwell daemon control
Cmnd_Alias MAXWELL_RESTART = /bin/systemctl restart maxwell-daemon.service
Cmnd_Alias MAXWELL_STATUS  = /bin/systemctl is-active maxwell-daemon.service

# Runner scheduler
Cmnd_Alias SCHEDULER_START   = /bin/systemctl --user start   runner-scheduler.service
Cmnd_Alias SCHEDULER_STOP    = /bin/systemctl --user stop    runner-scheduler.service
Cmnd_Alias SCHEDULER_STATUS  = /bin/systemctl --user is-active runner-scheduler.service

# --- Grant (substitute YOUR_USER with the actual service account name) --------
# The dashboard web process runs as YOUR_USER.  These rules let it call the
# above systemctl commands without a password.  No other commands are allowed.

YOUR_USER ALL=(root) NOPASSWD: DASHBOARD_RESTART, \
                                RUNNER_SVC_START, \
                                RUNNER_SVC_STOP, \
                                RUNNER_SVC_RESTART, \
                                RUNNER_SVC_STATUS, \
                                MAXWELL_RESTART, \
                                MAXWELL_STATUS, \
                                SCHEDULER_START, \
                                SCHEDULER_STOP, \
                                SCHEDULER_STATUS
